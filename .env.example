# Copy to .env.local and adjust.

# Use bundled mock feed (true) or hit the live HAF_FYP endpoint (false).
VITE_USE_MOCK=true

# DEV ONLY: where the Vite proxy forwards /v1/fyp/* (avoids CORS in dev).
# Point this at the testapi host that serves the FYP nginx clean URLs.
VITE_FYP_PROXY_TARGET=https://testapi.hive.blog

# PROD: public FYP origin the browser calls directly. Leave empty in dev to use
# the relative-path proxy above. The FYP nginx must send
# Access-Control-Allow-Origin for direct browser calls.
# VITE_FYP_BASE=https://your-fyp-host
